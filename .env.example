# ============================================================================
# meridian-scout — environment configuration
# Copy this file to `.env` and fill in the values. NEVER commit your real .env.
# Tunable *rules/thresholds* live in config.yaml, not here — this file is for
# secrets, credentials, and runtime knobs only.
# ============================================================================

# ---------------------------------------------------------------------------
# Scheduler
# ---------------------------------------------------------------------------
# How often to run a screening cycle, in minutes (default 5–10 recommended).
POLL_INTERVAL_MINUTES=7
# Run one cycle immediately on startup instead of waiting for the first tick.
RUN_ON_STARTUP=true

# ---------------------------------------------------------------------------
# Telegram (REQUIRED) — get a bot token from @BotFather, and your chat/channel
# id from @userinfobot (personal) or by adding the bot to a channel as admin.
# ---------------------------------------------------------------------------
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ---------------------------------------------------------------------------
# LLM analyzer — OpenRouter is the primary provider; DeepSeek-direct is the
# fallback used automatically if OpenRouter fails or is rate-limited.
# ---------------------------------------------------------------------------
# OpenRouter API key — https://openrouter.ai/keys  (REQUIRED for LLM stage)
OPENROUTER_API_KEY=
# DeepSeek direct API key — https://platform.deepseek.com  (OPTIONAL fallback)
DEEPSEEK_API_KEY=
# Model string sent to OpenRouter. Default is cheap + capable. Swap to
# deepseek/deepseek-r1 for deeper (pricier) reasoning.
LLM_MODEL=deepseek/deepseek-chat
# Model used when falling back to DeepSeek-direct (their native model id).
LLM_FALLBACK_MODEL=deepseek-chat
# Optional OpenRouter attribution headers (recommended for ranking/tracking).
OPENROUTER_HTTP_REFERER=https://github.com/rigaz29/meridian-scout
OPENROUTER_APP_TITLE=meridian-scout

# ---------------------------------------------------------------------------
# Jupiter enrichment (OPTIONAL key). Keyless requests work on the free tier
# (~0.5 RPS). Add a key from https://portal.jup.ag for higher rate limits.
# Endpoints used: https://datapi.jup.ag/v1  and  https://api.jup.ag
# ---------------------------------------------------------------------------
JUPITER_API_KEY=

# ---------------------------------------------------------------------------
# OKX DEX enrichment (OPTIONAL — enrichment is best-effort). Without these
# keys the OKX cross-check is skipped and the cycle continues. The OKX market
# endpoints now require authenticated requests (keyless hits a paywall).
# Create keys at https://web3.okx.com/build/dev-portal
# ---------------------------------------------------------------------------
OKX_API_KEY=
OKX_SECRET_KEY=
OKX_PASSPHRASE=
# Project id is required for some OKX Web3 API keys; leave blank if not issued.
OKX_PROJECT_ID=

# ---------------------------------------------------------------------------
# GMGN OpenAPI enrichment (OPTIONAL — best-effort). Adds smart-money / KOL
# wallet exposure, creator launch history, sniper/bundler counts, and launchpad
# bonding-curve progress via GET https://openapi.gmgn.ai/v1/token/info.
# Read/query routes need only this API key (no private key). Apply at
# https://gmgn.ai/ai. NOTE: the OpenAPI answers over IPv4 only — a 401/403 with
# a valid key usually means outbound traffic is going via IPv6.
# ---------------------------------------------------------------------------
GMGN_API_KEY=

# ---------------------------------------------------------------------------
# Logging
# ---------------------------------------------------------------------------
# debug | info | warn | error
LOG_LEVEL=info
# Set a path to also append logs to a file (e.g. logs/screener.log). Blank = console only.
LOG_FILE=
